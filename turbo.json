{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
