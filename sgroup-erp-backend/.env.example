# ═══════════════════════════════════════════════════════════════
# SGROUP ERP — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Database Adapter Selection ──────────────────────────────────
# Options: 'google-sheets' | 'prisma'
# - google-sheets: Reads/writes directly to Google Sheets (no DB needed)
# - prisma:        Reads/writes via Prisma ORM (PostgreSQL/Supabase/Neon)
DB_ADAPTER=prisma

# ── PostgreSQL (when DB_ADAPTER=prisma) ─────────────────────────
# Local:    postgresql://user:pass@localhost:5432/sgroup_erp
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Neon:     postgresql://user:pass@ep-xxx.neon.tech/sgroup_erp
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sgroup_erp

# ── Google Sheets (when DB_ADAPTER=google-sheets) ───────────────
# Create a Google Cloud Service Account and share the spreadsheet
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-sa-key.json

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# ── Bizfly CRM ──────────────────────────────────────────────────
BIZFLY_API_KEY=
BIZFLY_API_URL=

# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
