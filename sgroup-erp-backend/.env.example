# ═══════════════════════════════════════════════════════════════════
# SGROUP ERP — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Cách sử dụng:
#   1. Copy file này: cp .env.example .env
#   2. Điền tất cả giá trị có nhãn [REQUIRED]
#   3. KHÔNG commit file .env vào git (đã có trong .gitignore)
#
# Tạo JWT_SECRET ngẫu nhiên:
#   Linux/Mac:  openssl rand -base64 48
#   Windows PS: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
#
# ═══════════════════════════════════════════════════════════════════

# ── Môi trường ──────────────────────────────────────────────────
NODE_ENV=development
# Options: development | staging | production
PORT=3000

# ── Database Adapter ─────────────────────────────────────────────
# Options: prisma | google-sheets
# prisma:        Đọc/ghi qua Prisma ORM → PostgreSQL (recommended)
# google-sheets: Đọc/ghi trực tiếp Google Sheets (không cần DB)
DB_ADAPTER=prisma

# ── PostgreSQL (khi DB_ADAPTER=prisma) ──────────────────────────
# [REQUIRED]
# Local:      postgresql://postgres:postgres@localhost:5432/sgroup_erp
# Neon.tech:  postgresql://user:pass@ep-xxx.neon.tech/sgroup_erp?sslmode=require
# Supabase:   postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sgroup_erp

# ── Authentication ───────────────────────────────────────────────
# [REQUIRED] JWT signing secret — tối thiểu 32 ký tự
# Server sẽ KHÔNG khởi động nếu thiếu hoặc quá ngắn!
# Tạo: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Thời gian hết hạn access token
# Options: 1h | 8h | 1d (khuyến nghị 1d khi chưa có refresh token)
JWT_EXPIRES_IN=1d

# ── Frontend CORS ────────────────────────────────────────────────
# [REQUIRED trên production] URL chính xác của frontend app
# Ví dụ: https://erp.sgroup.vn
# Dev: để trống nếu dùng localhost:8081 (đã có trong whitelist)
FRONTEND_URL=http://localhost:8081

# ── Google Sheets (khi DB_ADAPTER=google-sheets) ────────────────
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-sa-key.json

# ── Bizfly CRM Integration ───────────────────────────────────────
BIZFLY_API_KEY=
BIZFLY_API_URL=https://manage.bizfly.vn/api

# ── AI Integration ───────────────────────────────────────────────
# Dùng cho AI module (phân tích dữ liệu, chatbot nội bộ)
ANTHROPIC_API_KEY=

# ── Seeding (chỉ dùng khi chạy seed scripts) ────────────────────
# Mật khẩu mặc định cho tất cả accounts khi seed — tối thiểu 8 ký tự
# QUAN TRỌNG: Xóa biến này khỏi .env sau khi seed xong!
# Cách dùng: SEED_DEFAULT_PASSWORD=StrongP@ss123 npm run seed:users
SEED_DEFAULT_PASSWORD=

# ── Upload ───────────────────────────────────────────────────────
UPLOAD_DIR=uploads
# Giới hạn kích thước file upload (bytes): 10MB = 10485760
MAX_FILE_SIZE=10485760
