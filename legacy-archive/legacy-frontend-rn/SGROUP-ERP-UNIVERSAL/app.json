{
  "expo": {
    "name": "SGROUP ERP",
    "slug": "sgroup-erp-universal",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/Logo 3_noFont.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Logo 3_noFont.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sgroup.erp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Logo 3_noFont.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.sgroup.erp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/Logo 3_noFont.png"
    }
  }
}
